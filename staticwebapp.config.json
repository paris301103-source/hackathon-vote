{
  "routes": [
    { "route": "/.auth/login/aad", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/.auth/*", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/*", "allowedRoles": ["member"] }
  ],
  "responseOverrides": {
    "401": { "statusCode": 302, "redirect": "/.auth/login/aad" }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/.auth/*"]
  }
}
